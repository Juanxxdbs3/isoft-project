# ── Aplicación ──────────────────────────────────────────────
APP_VERSION=0.3.0
APP_ENV=development

# ── Parámetros del IMB (contrato sección 10) ────────────────
IMB_WEIGHT_DEPRESSION=0.6
IMB_WEIGHT_ANXIETY=0.4

# ── Override suicida (contrato sección 10.2) ─────────────────
SUICIDE_OVERRIDE_THRESHOLD=60

# ── Rangos de clasificación por IMB ─────────────────────────
IMB_MEDIUM_THRESHOLD=40
IMB_HIGH_THRESHOLD=70

# ── Umbral mínimo de palabras para análisis semántico ────────
MIN_WORDS_FOR_ANALYSIS=20

# ── Contexto previo ──────────────────────────────────────────
MAX_CONTEXT_ENTRIES=5
MAX_CONTEXT_WORDS_PER_ENTRY=100

# ── Preprocesador ──────────────────────────────────────────
MIXED_LANGUAGE_THRESHOLD=0.4

# ── Stub del modelo (valores fijos para pruebas) ─────────────
STUB_P_DEPRESSION=40.0
STUB_P_ANXIETY=30.0
STUB_P_SUICIDAL=20.0
STUB_SCORE_NORMS=0.1

# ── Versiones de modelos (se actualizan en Fase 5) ───────────
CLINICAL_MODEL_VERSION=stub-v0.3
NORMS_MODEL_VERSION=stub-v0.3